# Datenbank (PostgreSQL - lokal via Docker oder Render-Managed-Postgres)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Server
PORT=4000
NODE_ENV=development

# Upload-Verzeichnis (relativ zum backend-Ordner)
UPLOAD_DIR=./uploads

# Erlaubte Frontend-Origin fuer CORS
CORS_ORIGIN=http://localhost:5173

# Maximale Upload-Groesse in Bytes (10 MB)
MAX_FILE_SIZE=10485760

# Admin-Bereich: JWT-Signaturschluessel fuer /admin (Frontend) bzw.
# /api/admin/* (Backend). Login erfolgt gegen die AdminUser-Tabelle
# (email+password), es gibt kein festes Master-Passwort mehr.
# In Produktion durch ein starkes, zufaellig generiertes Secret ersetzen.
JWT_SECRET=change-me-to-a-random-64-char-hex-string
