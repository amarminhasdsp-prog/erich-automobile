# Datenbank (PostgreSQL - lokal via Docker oder Render-Managed-Postgres)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Server
PORT=4000
NODE_ENV=development

# Upload-Verzeichnis (relativ zum backend-Ordner)
UPLOAD_DIR=./uploads

# Erlaubte Frontend-Origin fuer CORS
CORS_ORIGIN=http://localhost:5173

# Maximale Upload-Groesse in Bytes (10 MB)
MAX_FILE_SIZE=10485760

# Admin-Bereich: JWT-Signaturschluessel fuer /admin (Frontend) bzw.
# /api/admin/* (Backend). Login erfolgt gegen die AdminUser-Tabelle
# (email+password), es gibt kein festes Master-Passwort mehr.
# In Produktion durch ein starkes, zufaellig generiertes Secret ersetzen.
JWT_SECRET=change-me-to-a-random-64-char-hex-string

# --- mobile.de XML-Sync (Platzhalter) ---
# WICHTIG: mobile.de bietet aktuell keine oeffentlich buchbare Self-Service-
# API. Diese Werte muessen erst mit mobile.de (Haendler-/Partner-Support)
# geklaert und dort erfragt werden, bevor der Sync produktiv genutzt werden
# kann. Details siehe backend/docs/mobile-de-sync.md sowie der zugrunde
# liegende Recherche-Report.
#
# MOBILE_DE_SYNC_ENABLED=false ist der sichere Default: Der Scheduler startet
# den Sync-Job nur, wenn dieser Wert explizit auf "true" gesetzt UND echte
# Zugangsdaten (URL, Dealer-ID, API-Key) hinterlegt sind. Bei "false" bleibt
# der Sync deaktiviert und der Code fuehrt keine Netzwerkaufrufe gegen die
# Platzhalter-URL aus.
MOBILE_DE_FEED_URL=https://REPLACE_ME.example/feed
MOBILE_DE_DEALER_ID=REPLACE_ME
MOBILE_DE_API_KEY=REPLACE_ME
MOBILE_DE_SYNC_INTERVAL_CRON="0 */2 * * *"
MOBILE_DE_SYNC_ENABLED=false
MOBILE_DE_FEED_TIMEOUT_MS=15000
MOBILE_DE_SANITY_CHECK_MAX_DROP_PERCENT=50

