{
  "name": "autohaendler-backend",
  "version": "1.0.0",
  "description": "Backend fuer Autohaendler-Portal (Fahrzeugverwaltung mit Fotos und Dokumenten)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p .",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "ts-node prisma/seed.ts",
    "sync:verify": "ts-node src/sync/__fixtures__/verify.ts"
  },
  "dependencies": {
    "@prisma/client": "5.19.1",
    "bcrypt": "5.1.1",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.22.2",
    "express-rate-limit": "8.6.0",
    "fast-xml-parser": "4.5.0",
    "file-type": "21.3.4",
    "helmet": "7.1.0",
    "jsonwebtoken": "9.0.2",
    "multer": "2.2.0",
    "node-cron": "3.0.3",
    "zod": "3.23.8"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcrypt": "5.0.2",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.7",
    "@types/multer": "1.4.13",
    "@types/node": "20.14.15",
    "@types/node-cron": "3.0.11",
    "prisma": "5.19.1",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "typescript": "5.5.4"
  }
}
